      "loop": false,
      "frames": [
        {
          "index": 4,
          "durationMs": 90
        },
        {
          "index": 5,
          "durationMs": 120
        },
        {
          "index": 6,
          "durationMs": 120
        }
      ],
      "next": "idle"
